{
  "name": "clipboard-manager",
  "version": "1.0.0",
  "description": "Fast clipboard history manager for Linux",
  "main": "./out/main/index.js",
  "author": {
    "name": "Suraj Kolhe",
    "email": "surajkolhe214@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/kolhesuraj/clipboard-manager-website",
  "scripts": {
    "dev": "ELECTRON_EXEC_PATH=scripts/electron electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite build && ELECTRON_EXEC_PATH=scripts/electron electron-vite preview",
    "start": "ELECTRON_EXEC_PATH=scripts/electron electron-vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dist": "electron-vite build && electron-builder --linux",
    "postinstall": "electron-rebuild -f -w better-sqlite3 && node create-icon.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@eslint/js": "^9.5.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "eslint": "^9.5.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "typescript": "^5.5.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.3.1"
  },
  "dependencies": {
    "better-sqlite3": "^11.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "build": {
    "appId": "com.clipboardmanager.app",
    "productName": "Clipboard Manager",
    "icon": "resources/icon-512.png",
    "files": [
      "out/**/*",
      "resources/icon-512.png"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon-512.png",
      "category": "Utility",
      "description": "Fast clipboard history manager for Linux",
      "synopsis": "Clipboard history manager"
    },
    "deb": {
      "depends": [
        "libnotify4",
        "libxtst6",
        "libnss3",
        "libsecret-1-0"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "kolhesuraj",
      "repo": "clipboard-manager"
    }
  }
}
